@prefix : <http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#> .

<http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog> rdf:type owl:Ontology ;
                                                                          rdfs:comment "This ontology models medical devices, risks, incidents, manufacturers and regulatory risk classes in the healthcare domain." ;
                                                                          rdfs:label "Medical Device Catalog Ontology" ;
                                                                          owl:versionInfo "v1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#sameAs
owl:sameAs rdf:type owl:AnnotationProperty ;
           rdfs:subPropertyOf rdfs:comment .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#addressesIncident
:addressesIncident rdf:type owl:ObjectProperty ;
                   rdfs:domain :CorrectiveAction ;
                   rdfs:range :Incident ;
                   rdfs:comment "Indicates which incident is addressed by a corrective action" ;
                   rdfs:label "addresses incident" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#affectsDevice
:affectsDevice rdf:type owl:ObjectProperty ;
               rdfs:domain :Incident ;
               rdfs:range :Device ;
               rdfs:comment "Indicates which device is affected by an incident" ;
               rdfs:label "affects device" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ;
                 rdfs:domain :Device ;
                 rdfs:range :Manufacturer ;
                 rdfs:comment "Relates a device to its manufacturer" ;
                 rdfs:label "has manufacturer" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#hasRisk
:hasRisk rdf:type owl:ObjectProperty ;
         rdfs:domain :Device ;
         rdfs:range :Risk ;
         rdfs:comment "Indicates a risk associated with a device" ;
         rdfs:label "has risk" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              rdfs:domain :Device ;
              rdfs:range :RiskClass ;
              rdfs:comment "Indicates the regulatory risk classification of a device" ;
              rdfs:label "has risk class" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#locatedIn
:locatedIn rdf:type owl:ObjectProperty ;
           rdfs:domain :Manufacturer ;
           rdfs:range :Country ;
           rdfs:comment "Indicates the country where a manufacturer is located" ;
           rdfs:label "located in" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#relatedToRisk
:relatedToRisk rdf:type owl:ObjectProperty ;
               rdfs:domain :Incident ;
               rdfs:range :Risk ;
               rdfs:comment "Indicates the risk involved in an incident" ;
               rdfs:label "related to risk" .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#actionDate
:actionDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :CorrectiveAction ;
            rdfs:range xsd:dateTime ;
            rdfs:comment "Date when a corrective action was taken" ;
            rdfs:label "action date" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#authorizationNumber
:authorizationNumber rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Official authorization number of the manufacturer" ;
                     rdfs:label "authorization number" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#deviceID
:deviceID rdf:type owl:DatatypeProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:string ;
          rdfs:comment "Unique identifier of a device" ;
          rdfs:label "device ID" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#incidentDescription
:incidentDescription rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Textual description of an incident" ;
                     rdfs:label "incident description" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#manufacturerName
:manufacturerName rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Manufacturer ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Name of the manufacturer" ;
                  rdfs:label "manufacturer name" .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :MedicalDevice ;
              rdfs:comment "A device that requires a source of energy to operate" ;
              rdfs:label "Active Device" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#AdverseEvent
:AdverseEvent rdf:type owl:Class ;
              rdfs:subClassOf :Incident ;
              rdfs:comment "An incident that caused minor or moderate harm" ;
              rdfs:label "Adverse Event" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#BiologicalRisk
:BiologicalRisk rdf:type owl:Class ;
                rdfs:subClassOf :Risk ;
                rdfs:comment "A risk related to biological contamination or reaction" ;
                rdfs:label "Biological Risk" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#ClassA
:ClassA rdf:type owl:Class ;
        rdfs:subClassOf :IVDRRiskClass ;
        rdfs:comment "Lowest risk class for in vitro diagnostic devices" ;
        rdfs:label "Class A" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#ClassB
:ClassB rdf:type owl:Class ;
        rdfs:subClassOf :IVDRRiskClass ;
        rdfs:comment "Low-medium risk class for in vitro diagnostic devices" ;
        rdfs:label "Class B" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#ClassC
:ClassC rdf:type owl:Class ;
        rdfs:subClassOf :IVDRRiskClass ;
        rdfs:comment "Medium-high risk class for in vitro diagnostic devices" ;
        rdfs:label "Class C" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#ClassD
:ClassD rdf:type owl:Class ;
        rdfs:subClassOf :IVDRRiskClass ;
        rdfs:comment "Highest risk class for in vitro diagnostic devices" ;
        rdfs:label "Class D" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#ClassI
:ClassI rdf:type owl:Class ;
        rdfs:subClassOf :MDRRiskClass ;
        rdfs:comment "Low risk medical device class" ;
        rdfs:label "Class I" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#ClassIII
:ClassIII rdf:type owl:Class ;
          rdfs:subClassOf :MDRRiskClass ;
          rdfs:comment "High risk medical device class" ;
          rdfs:label "Class III" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#ClassIIa
:ClassIIa rdf:type owl:Class ;
          rdfs:subClassOf :MDRRiskClass ;
          rdfs:comment "Medium-low risk medical device class" ;
          rdfs:label "Class IIa" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#ClassIIb
:ClassIIb rdf:type owl:Class ;
          rdfs:subClassOf :MDRRiskClass ;
          rdfs:comment "Medium-high risk medical device class" ;
          rdfs:label "Class IIb" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:comment "An action taken to address an incident" ;
                  rdfs:label "Corrective Action" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#Country
:Country rdf:type owl:Class ;
         rdfs:comment "A country where a manufacturer is located" ;
         rdfs:label "Country" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasManufacturer ;
                          owl:someValuesFrom :Manufacturer
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasRiskClass ;
                          owl:someValuesFrom :RiskClass
                        ] ;
        rdfs:comment "A general medical device registered in the system" ;
        rdfs:label "Device" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#ElectricalRisk
:ElectricalRisk rdf:type owl:Class ;
                rdfs:subClassOf :Risk ;
                rdfs:comment "A risk related to electrical components or failures" ;
                rdfs:label "Electrical Risk" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#FieldSafetyNotice
:FieldSafetyNotice rdf:type owl:Class ;
                   rdfs:subClassOf :CorrectiveAction ;
                   rdfs:comment "A communication issued to inform users about device risks" ;
                   rdfs:label "Field Safety Notice" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#HighRiskDevice
:HighRiskDevice rdf:type owl:Class ;
                rdfs:subClassOf :MedicalDevice ;
                rdfs:comment "A medical device classified as high risk according to MDR or IVDR" ;
                rdfs:label "High Risk Device" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#IVDRRiskClass
:IVDRRiskClass rdf:type owl:Class ;
               rdfs:subClassOf :RiskClass ;
               rdfs:comment "Risk classification according to IVDR regulation" ;
               rdfs:label "IVDR Risk Class" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :MedicalDevice ;
                   rdfs:comment "A device intended to be totally or partially introduced into the human body" ;
                   rdfs:label "Implantable Device" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :MedicalDevice ;
                         rdfs:comment "A device used for in vitro diagnostic purposes under IVDR regulation" ;
                         rdfs:label "In Vitro Diagnostic Device" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#Incident
:Incident rdf:type owl:Class ;
          rdfs:comment "An event associated with a device that may cause harm" ;
          rdfs:label "Incident" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#MDRRiskClass
:MDRRiskClass rdf:type owl:Class ;
              rdfs:subClassOf :RiskClass ;
              rdfs:comment "Risk classification according to MDR regulation" ;
              rdfs:label "MDR Risk Class" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:comment "An organization responsible for producing medical devices" ;
              rdfs:label "Manufacturer" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#MechanicalRisk
:MechanicalRisk rdf:type owl:Class ;
                rdfs:subClassOf :Risk ;
                rdfs:comment "A risk caused by mechanical failure or malfunction" ;
                rdfs:label "Mechanical Risk" ;
                rdfs:seeAlso <http://dbpedia.org/resource/Mechanical_engineering> .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#MedicalDevice
:MedicalDevice rdf:type owl:Class ;
               rdfs:subClassOf :Device ;
               rdfs:comment "A device used for medical purposes under MDR regulation" ;
               rdfs:label "Medical Device" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :CorrectiveAction ;
        rdfs:comment "An action to remove a device from the market" ;
        rdfs:label "Recall" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#Risk
:Risk rdf:type owl:Class ;
      rdfs:comment "A potential hazard associated with a medical device" ;
      rdfs:label "Risk" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:comment "A classification indicating the level of risk of a device" ;
           rdfs:label "Risk Class" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident ;
                 rdfs:comment "An incident that caused serious harm or death" ;
                 rdfs:label "Serious Incident" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#SoftwareRisk
:SoftwareRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "A risk caused by software malfunction or bugs" ;
              rdfs:label "Software Risk" .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#BatteryFailureRisk
:BatteryFailureRisk rdf:type owl:NamedIndividual ,
                             :MechanicalRisk ;
                    rdfs:comment "Risk related to battery malfunction" ;
                    rdfs:label "Battery Failure Risk" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#HeartMonitorX
:HeartMonitorX rdf:type owl:NamedIndividual ,
                        :MedicalDevice ;
               :hasManufacturer :MedTechCorp ;
               :hasRisk :BatteryFailureRisk ;
               rdfs:comment "A medical device used to monitor heart activity" ;
               rdfs:label "Heart Monitor X" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#MedTechCorp
:MedTechCorp rdf:type owl:NamedIndividual ,
                      :Manufacturer ;
             rdfs:comment "A company that manufactures medical devices" ;
             rdfs:label "MedTech Corp" ;
             rdfs:seeAlso <http://dbpedia.org/resource/Medical_device> .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#OverheatingIncident
:OverheatingIncident rdf:type owl:NamedIndividual ,
                              :Incident ;
                     :affectsDevice :HeartMonitorX ;
                     rdfs:comment "An incident where a device overheats" ;
                     rdfs:label "Overheating Incident" .


###  http://www.semanticweb.org/jose/ontologies/2026/medical-device-catalog#Spain
:Spain rdf:type owl:NamedIndividual ,
                :Country ;
       rdfs:comment "A country in Europe" ;
       rdfs:label "Spain" ;
       rdfs:seeAlso <http://dbpedia.org/resource/Spain> .


